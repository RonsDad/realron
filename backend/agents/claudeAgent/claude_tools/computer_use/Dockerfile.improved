FROM ubuntu:22.04

# Avoid prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install X11, desktop environment and required tools
RUN apt-get update && apt-get install -y \
    # X11 and VNC
    xvfb \
    x11vnc \
    novnc \
    websockify \
    # Desktop environment and session management
    xfce4 \
    xfce4-terminal \
    xfce4-session \
    xfce4-panel \
    xfce4-settings \
    xfce4-power-manager \
    xfce4-screensaver \
    # System services and dbus
    dbus \
    dbus-x11 \
    systemd \
    policykit-1 \
    policykit-1-gnome \
    at-spi2-core \
    # Audio support (to fix pulseaudio errors)
    pulseaudio \
    pulseaudio-utils \
    # Additional system utilities
    pm-utils \
    upower \
    udisks2 \
    gvfs \
    gvfs-backends \
    gvfs-fuse \
    # Color management (to fix colord errors)
    colord \
    # Automation tools
    xdotool \
    imagemagick \
    x11-utils \
    # Development tools
    python3 \
    python3-pip \
    curl \
    wget \
    git \
    nodejs \
    npm \
    # Browsers
    firefox \
    chromium-browser \
    # Utilities
    sudo \
    net-tools \
    gnupg2 \
    ca-certificates \
    locales \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Configure locale
RUN locale-gen en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Install Python dependencies
RUN pip3 install --no-cache-dir \
    anthropic \
    pymongo \
    pillow \
    asyncio \
    aiofiles

# Create non-root user with proper groups
RUN useradd -m -s /bin/bash -G audio,video,plugdev claude && \
    echo 'claude ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

# Create necessary directories with proper permissions
RUN mkdir -p /tmp/claude_screenshots && \
    mkdir -p /home/claude/.vnc && \
    mkdir -p /home/claude/Desktop && \
    mkdir -p /home/claude/.config && \
    mkdir -p /home/claude/.local/share && \
    mkdir -p /home/claude/.cache && \
    mkdir -p /run/user/1000 && \
    mkdir -p /var/run/dbus && \
    mkdir -p /tmp/.X11-unix && \
    mkdir -p /tmp/.ICE-unix && \
    chmod 1777 /tmp/.X11-unix && \
    chmod 1777 /tmp/.ICE-unix && \
    chown -R claude:claude /home/claude /tmp/claude_screenshots /run/user/1000

# Copy the computer use tool
COPY --chown=claude:claude computer_use_tool.py /home/claude/
COPY --chown=claude:claude __init__.py /home/claude/

# Create improved startup script
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Function to log messages\n\
log() {\n\
    echo "[$(date +"%Y-%m-%d %H:%M:%S")] $1"\n\
}\n\
\n\
# Clean up any existing locks\n\
rm -f /tmp/.X1-lock /tmp/.X11-unix/X1\n\
\n\
# Set up environment variables\n\
export DISPLAY=:1\n\
export XDG_RUNTIME_DIR=/run/user/1000\n\
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus\n\
export HOME=/home/claude\n\
export USER=claude\n\
\n\
# Start dbus if not running\n\
if [ ! -f /var/run/dbus/pid ]; then\n\
    log "Starting D-Bus daemon..."\n\
    sudo mkdir -p /var/run/dbus\n\
    sudo dbus-daemon --system --fork || true\n\
fi\n\
\n\
# Start a session dbus\n\
log "Starting session D-Bus..."\n\
eval $(dbus-launch --sh-syntax) || true\n\
\n\
# Start Xvfb with better error handling\n\
log "Starting Xvfb..."\n\
Xvfb :1 -screen 0 1280x1024x24 -ac +extension GLX +render -noreset &\n\
XVFB_PID=$!\n\
sleep 2\n\
\n\
# Verify Xvfb is running\n\
if ! kill -0 $XVFB_PID 2>/dev/null; then\n\
    log "ERROR: Xvfb failed to start"\n\
    exit 1\n\
fi\n\
\n\
# Create necessary runtime directories\n\
mkdir -p $XDG_RUNTIME_DIR\n\
chmod 700 $XDG_RUNTIME_DIR\n\
\n\
# Start PulseAudio in system mode (containerized)\n\
log "Starting PulseAudio..."\n\
pulseaudio --system --disallow-exit --disallow-module-loading=1 --daemonize || true\n\
\n\
# Start XFCE desktop with proper session management\n\
log "Starting XFCE desktop environment..."\n\
export XDG_SESSION_TYPE=x11\n\
export XDG_CURRENT_DESKTOP=XFCE\n\
startxfce4 &\n\
sleep 5\n\
\n\
# Disable screensaver and power management\n\
xset -dpms || true\n\
xset s off || true\n\
xset s noblank || true\n\
\n\
# Start VNC server without password for easy access\n\
log "Starting VNC server..."\n\
x11vnc -display :1 -nopw -forever -xkb -shared -repeat -noxdamage &\n\
VNC_PID=$!\n\
\n\
# Start NoVNC (web-based VNC)\n\
log "Starting NoVNC web server..."\n\
websockify --web=/usr/share/novnc/ 6080 localhost:5900 &\n\
NOVNC_PID=$!\n\
\n\
# Wait a moment for services to stabilize\n\
sleep 2\n\
\n\
# Verify services are running\n\
if kill -0 $VNC_PID 2>/dev/null && kill -0 $NOVNC_PID 2>/dev/null; then\n\
    log "✅ All services started successfully!"\n\
    log "📺 VNC access: vnc://localhost:5900"\n\
    log "🌐 Web access: http://localhost:6080/vnc.html"\n\
    log "🖥️  Display: $DISPLAY"\n\
else\n\
    log "⚠️  Some services may have failed to start"\n\
fi\n\
\n\
# Keep container running and monitor services\n\
while true; do\n\
    if ! kill -0 $XVFB_PID 2>/dev/null; then\n\
        log "WARNING: Xvfb has stopped, restarting..."\n\
        Xvfb :1 -screen 0 1280x1024x24 -ac +extension GLX +render -noreset &\n\
        XVFB_PID=$!\n\
    fi\n\
    sleep 30\n\
done' > /home/claude/start.sh && \
    chmod +x /home/claude/start.sh

# Create xfce4 config to suppress some warnings
RUN mkdir -p /home/claude/.config/xfce4/xfconf/xfce-perchannel-xml && \
    echo '<?xml version="1.0" encoding="UTF-8"?>\n\
<channel name="xfce4-session" version="1.0">\n\
  <property name="general" type="empty">\n\
    <property name="FailsafeSessionName" type="string" value="Failsafe"/>\n\
    <property name="SaveOnExit" type="bool" value="false"/>\n\
  </property>\n\
  <property name="shutdown" type="empty">\n\
    <property name="LockScreen" type="bool" value="false"/>\n\
  </property>\n\
</channel>' > /home/claude/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-session.xml && \
    chown -R claude:claude /home/claude/.config

# Switch to claude user
USER claude
WORKDIR /home/claude

# Expose ports
EXPOSE 5900 6080

# Set environment variables
ENV DISPLAY=:1
ENV HOME=/home/claude
ENV USER=claude
ENV XDG_RUNTIME_DIR=/run/user/1000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD xdpyinfo -display :1 >/dev/null 2>&1 || exit 1

CMD ["/home/claude/start.sh"]